# ============================================
# LLM API Configuration
# ============================================
# Choose ONE of the following LLM providers by uncommenting the relevant section

# --- Azure OpenAI (Default/Currently Active) ---
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL_NAME=gpt-4o-mini

# --- Google Gemini (Alternative) ---
# Option 1: AI Studio (Simpler setup)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-pro

# Option 2: Vertex AI (For enterprise use)
# GEMINI_PROJECT_ID=your-gcp-project-id
# GEMINI_LOCATION=us-central1
# GEMINI_MODEL=gemini-2.5-pro

# --- Other LLM Providers (Optional) ---
# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI
# OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# GitHub Configuration
# ============================================
# Required for accessing private repositories or avoiding rate limits
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-personal-access-token-here

# ============================================
# Application Configuration
# ============================================
# Directory for storing log files (default: logs)
LOG_DIR=logs

# ============================================
# Notes
# ============================================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit your .env file to version control
# 3. The Azure OpenAI configuration is currently active in the code
# 4. To switch LLM providers, edit utils/call_llm.py and uncomment the desired implementation
# 5. GITHUB_TOKEN is optional but recommended to avoid API rate limits
